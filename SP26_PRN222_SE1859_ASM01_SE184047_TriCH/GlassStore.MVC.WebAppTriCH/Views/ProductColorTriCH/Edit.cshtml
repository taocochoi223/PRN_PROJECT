@model GlassStore.Entities.TriCH.Models.ProductColorTriCh

<h2>Chỉnh sửa màu</h2>
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ColorTriChid" />
    <input type="hidden" asp-for="ProductTriChid" />

    <div class="mb-3">
        <label asp-for="ColorName" class="form-label">Tên màu</label>
        <input asp-for="ColorName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="ColorCode" class="form-label">Mã màu</label>
        <input asp-for="ColorCode" class="form-control" type="color" />
    </div>
    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label">Tồn kho</label>
        <input asp-for="StockQuantity" class="form-control" type="number" />
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" asp-route-productId="@Model.ProductTriChid" class="btn btn-secondary">Hủy</a>
</form>
