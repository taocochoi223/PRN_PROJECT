@model GlassStore.Entities.TriCH.Models.ProductColorTriCh

@{
    ViewData["Title"] = "Xóa màu sắc";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Xác nhận xóa màu sắc</h4>
                </div>
                <div class="card-body">
                    <p class="lead">Bạn có chắc chắn muốn xóa màu này không? Hành động này không thể hoàn tác.</p>
                    
                    <div class="mb-4">
                        <table class="table table-bordered">
                            <tr>
                                <th style="width: 150px;" class="bg-light">Tên màu:</th>
                                <td>@Model.ColorName</td>
                            </tr>
                            <tr>
                                <th class="bg-light">Mã màu:</th>
                                <td>
                                    <span style="background-color:@Model.ColorCode; padding:5px 15px; border-radius:4px; border: 1px solid #dee2e6; margin-right: 10px;"></span>
                                    <code>@Model.ColorCode</code>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light">Số lượng tồn:</th>
                                <td>@Model.StockQuantity</td>
                            </tr>
                        </table>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" name="id" value="@Model.ColorTriChid" />
                        <input type="hidden" name="productId" value="@Model.ProductTriChid" />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" asp-route-productId="@Model.ProductTriChid" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Xác nhận xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="alert alert-warning mt-4">
                <i class="bi bi-exclamation-triangle-fill"></i> 
                <strong>Lưu ý:</strong> Xóa màu sắc có thể ảnh hưởng đến các hình ảnh và đơn hàng liên quan đến màu này.
            </div>
        </div>
    </div>
</div>
