<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GlassStore TriCH</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Nhúng Font & Icon -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GlassStore.MVC.WebAppTriCH.styles.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }

        /* Navbar đẹp hơn */
        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: #0d6efd !important;
            letter-spacing: -0.5px;
        }

        .nav-link {
            font-weight: 500;
            transition: color 0.3s;
            margin: 0 5px;
        }

            .nav-link:hover {
                color: #0d6efd !important;
            }

        .badge-cart {
            position: absolute;
            top: -5px;
            right: -5px;
            font-size: 0.7rem;
            padding: 0.35em 0.5em;
        }

        .btn-icon {
            position: relative;
            border: none;
            background: none;
            transition: transform 0.2s;
        }

            .btn-icon:hover {
                transform: scale(1.1);
            }

        /* SỬA LỖI FOOTER ĐÈ LÊN NỘI DUNG */
        /* Override lại style mặc định của template */
        .footer {
            position: relative !important; /* Bắt buộc footer chạy theo dòng chảy của trang */
            bottom: auto !important;
            width: 100%;
            white-space: normal !important; /* Cho phép xuống dòng nếu cần */
            line-height: normal !important; /* Reset chiều cao dòng */
        }

        /* Đảm bảo body không bị margin dưới (template cũ hay có margin-bottom: 60px) */
        body {
            margin-bottom: 0 !important;
        }

        .footer-shadow {
            box-shadow: 0 -5px 20px rgba(0,0,0,0.05);
        }
    </style>
</head>
<!-- Thêm d-flex flex-column min-vh-100 để footer luôn ở đáy nếu trang ngắn -->
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-eyeglasses me-2"></i> GlassStore <span class="text-dark ms-1 opacity-75 fs-6 text-uppercase">TriCH</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="ProductTriCH" asp-action="Index">Sản phẩm</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                               Đơn Hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <a class="nav-link btn-icon text-dark p-0" href="#">
                                <i class="bi bi-cart3 fs-4"></i>
                                <span class="badge bg-danger rounded-pill badge-cart">3</span>
                            </a>
                        </li>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <!-- Hiển thị khi ĐÃ đăng nhập -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                        <strong>@User.FindFirst("FullName")?.Value?.Substring(0, 1).ToUpper()</strong>
                                    </div>
                                    <span class="fw-semibold">@User.FindFirst("FullName")?.Value</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2">
                                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Hồ sơ của tôi</a></li>
                                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-box-seam me-2"></i>Đơn hàng</a></li>
                                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- Hiển thị khi CHƯA đăng nhập -->
                            <li class="nav-item">
                                <a class="btn btn-outline-primary rounded-pill px-4 btn-sm fw-bold" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-person-circle me-1"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- QUAN TRỌNG: Bỏ class "container" ở đây để nội dung bên trong được tràn viền (full-width) -->
    <!-- Thêm flex-grow-1 để đẩy footer xuống đáy -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted bg-light py-4 mt-auto footer-shadow">
        <div class="container text-center">
            <div class="mb-2">
                <a href="#" class="text-decoration-none text-muted mx-2"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-decoration-none text-muted mx-2"><i class="bi bi-instagram"></i></a>
                <a href="#" class="text-decoration-none text-muted mx-2"><i class="bi bi-tiktok"></i></a>
            </div>
            <small>
                &copy; 2026 - <strong>GlassStore TriCH</strong> - Uy tín tạo nên thương hiệu <br>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-secondary">Chính sách bảo mật</a> &bull;
                <a href="#" class="text-decoration-none text-secondary">Điều khoản sử dụng</a>
            </small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>