@model GlassStore.Entities.TriCH.Models.CategoryTriCh

@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                 <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Chỉnh sửa danh mục</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="CategoryTriChid" />
                        
                        <div class="mb-3">
                            <label asp-for="CategoryName" class="form-label">Tên danh mục</label>
                            <input asp-for="CategoryName" class="form-control" />
                            <span asp-validation-for="CategoryName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label">Slug (URL)</label>
                            <input asp-for="Slug" class="form-control" />
                            <span asp-validation-for="Slug" class="text-danger"></span>
                        </div>

                         <div class="mb-3">
                            <label asp-for="Status" class="form-label">Trạng thái</label>
                            <select asp-for="Status" class="form-select">
                                <option value="1">Hoạt động</option>
                                <option value="0">Ẩn</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                         <div class="d-flex justify-content-end gap-2">
                             <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
