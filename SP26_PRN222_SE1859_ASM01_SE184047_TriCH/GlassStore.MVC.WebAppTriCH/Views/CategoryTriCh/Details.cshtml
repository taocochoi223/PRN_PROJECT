@model GlassStore.Entities.TriCH.Models.CategoryTriCh

@{
    ViewData["Title"] = "Chi tiết danh mục";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Chi tiết danh mục</h4>
                    <a asp-action="Index" class="btn btn-light btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
                <div class="card-body">
                    <div class="mb-4 text-center">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-tag-fill fs-1 text-info"></i>
                        </div>
                        <h3 class="fw-bold">@Model.CategoryName</h3>
                    </div>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Mã danh mục</span>
                            <span class="fw-semibold">@Model.CategoryTriChid</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Slug</span>
                            <span class="badge bg-secondary">@Model.Slug</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Trạng thái</span>
                            @if (Model.Status == 1)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ẩn</span>
                            }
                        </li>
                    </ul>

                    <div class="mt-4 d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.CategoryTriChid" class="btn btn-primary">
                            <i class="bi bi-pencil-square"></i> Chỉnh sửa danh mục
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
