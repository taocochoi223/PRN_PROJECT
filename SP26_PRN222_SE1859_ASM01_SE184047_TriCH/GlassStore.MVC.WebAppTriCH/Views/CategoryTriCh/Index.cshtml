@model IEnumerable<GlassStore.Entities.TriCH.Models.CategoryTriCh>

@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Quản lý Danh mục</h1>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Thêm mới</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Tên danh mục</th>
                            <th>Slug</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4">@item.CategoryTriChid</td>
                                <td class="fw-bold">@item.CategoryName</td>
                                <td class="text-muted">@item.Slug</td>
                                <td>
                                    @if(item.Status == 1)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ẩn</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.CategoryTriChid" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.CategoryTriChid" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
