@model GlassStore.Entities.TriCH.Models.CategoryTriCh

@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Thêm danh mục mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="CategoryName" class="form-label">Tên danh mục</label>
                            <input asp-for="CategoryName" class="form-control" id="category-name" />
                            <span asp-validation-for="CategoryName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label">Slug (URL)</label>
                            <input asp-for="Slug" class="form-control" id="category-slug" readonly />
                            <span asp-validation-for="Slug" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Trạng thái</label>
                            <select asp-for="Status" class="form-select">
                                <option value="1">Hoạt động</option>
                                <option value="0">Ẩn</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                             <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-success">Create</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')           // Thay khoảng trắng bằng -
                .replace(/[^\w\-]+/g, '')       // Loại bỏ ký tự đặc biệt
                .replace(/\-\-+/g, '-')         // Thay nhiều - bằng một -
                .replace(/^-+/, '')             // Loại bỏ - ở đầu
                .replace(/-+$/, '');            // Loại bỏ - ở cuối
        }

        document.getElementById('category-name').addEventListener('input', function() {
            var name = this.value;
            var slug = generateSlug(name);
            document.getElementById('category-slug').value = slug;
        });
    </script>
}
