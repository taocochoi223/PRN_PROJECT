@model List<GlassStore.Entities.TriCH.Models.ProductImageTriCh>

@{
    ViewData["Title"] = "Quản lý hình ảnh";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý hình ảnh - <span class="text-primary">@ViewBag.ProductName</span></h2>
        <div>
            <a asp-action="Create" asp-route-productId="@ViewBag.ProductId" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> Thêm ảnh
            </a>
            <a asp-controller="ProductTriCH" asp-action="Manage" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Link ảnh</th>
                            <th>Chính?</th>
                            <th>Thứ tự</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Sản phẩm này chưa có hình ảnh nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="@item.ImageUrl" class="rounded" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/80x80?text=Error'">
                                    </td>
                                    <td class="text-truncate" style="max-width: 250px;">
                                        <a href="@item.ImageUrl" target="_blank" class="text-decoration-none">@item.ImageUrl</a>
                                    </td>
                                    <td>
                                        @if (item.IsPrimary == true)
                                        {
                                            <span class="badge bg-primary">Ảnh chính</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">Phụ</span>
                                        }
                                    </td>
                                    <td>@item.DisplayOrder</td>
                                    <td>
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@item.ImageTriChid" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.ImageTriChid" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
