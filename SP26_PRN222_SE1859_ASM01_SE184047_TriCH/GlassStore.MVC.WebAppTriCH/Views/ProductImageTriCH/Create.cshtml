@model GlassStore.Entities.TriCH.Models.ProductImageTriCh

@{
    ViewData["Title"] = "Thêm hình ảnh";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Thêm hình ảnh mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ProductTriChid" />

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label">Link ảnh (URL)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ColorTriChid" class="form-label">Gắn với màu sắc (Tùy chọn)</label>
                            <select asp-for="ColorTriChid" class="form-select" asp-items="ViewBag.Colors">
                                <option value="">-- Tất cả màu --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" id="IsPrimary" name="IsPrimary" value="true" class="form-check-input" @(Model?.IsPrimary == true ? "checked" : "") />
                            <input type="hidden" name="IsPrimary" value="false" />
                            <label class="form-check-label" for="IsPrimary">Đặt làm ảnh chính</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" asp-route-productId="@Model.ProductTriChid" class="btn btn-outline-secondary">Hủy</a>
                            <button type="submit" class="btn btn-success">Lưu lại</button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <p class="text-muted small">Mẹo: Bạn có thể sử dụng link từ các dịch vụ lưu trữ ảnh hoặc link ảnh trực tiếp.</p>
                <div id="imagePreviewContainer" class="mt-3 d-none">
                    <p class="mb-1">Xem trước:</p>
                    <img id="imagePreview" src="" class="img-thumbnail" style="max-height: 200px;">
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('ImageUrl').addEventListener('input', function() {
            var url = this.value;
            var preview = document.getElementById('imagePreview');
            var container = document.getElementById('imagePreviewContainer');
            if (url) {
                preview.src = url;
                container.classList.remove('d-none');
            } else {
                container.classList.add('d-none');
            }
        });
    </script>
}
