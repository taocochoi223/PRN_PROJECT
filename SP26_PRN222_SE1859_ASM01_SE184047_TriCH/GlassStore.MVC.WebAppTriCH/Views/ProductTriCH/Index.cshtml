@model IEnumerable<GlassStore.Entities.TriCH.Models.ProductTriCh>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_LayoutAdmin";
    int currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    int totalPages  = (int)(ViewData["TotalPages"] ?? 1);
    string? search  = ViewData["Search"] as string;
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Quản lý Sản phẩm</h1>
        @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "1")
        {
            <a asp-action="Create" class="btn btn-success">Create New</a>
        }
    </div>

    @* ----- Thanh tìm kiếm ----- *@
    <form method="get" asp-action="Index" class="mb-3">
        <div class="input-group" style="max-width: 400px;">
            <input type="text" name="search" value="@search"
                   class="form-control"
                   placeholder="Tìm tên sản phẩm..." />
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search"></i> Tìm
            </button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">✕ Xóa</a>
            }
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th>Kho</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@item.ProductName</div>
                                    <small class="text-muted">ID: @item.ProductTriChid</small>
                                </td>
                                <td>@item.CategoryTriCh?.CategoryName</td>
                                <td>@item.Price.ToString("N0") đ</td>
                                <td>
                                    @if(item.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">@item.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết hàng</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == 1)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngừng bán</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "1")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.ProductTriChid" class="btn btn-primary">Edit</a>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.ProductTriChid" class="btn btn-info text-white">Details</a>
                                        @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "1")
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.ProductTriChid" class="btn btn-danger">Delete</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ----- Phân trang động ----- *@
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                @* Nút Previous *@
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       href="@Url.Action("Index", new { page = currentPage - 1, search })">‹ Trước</a>
                </li>

                @* Các số trang *@
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { page = i, search })">@i</a>
                    </li>
                }

                @* Nút Next *@
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       href="@Url.Action("Index", new { page = currentPage + 1, search })">Sau ›</a>
                </li>

            </ul>
        </nav>
    }
</div>
