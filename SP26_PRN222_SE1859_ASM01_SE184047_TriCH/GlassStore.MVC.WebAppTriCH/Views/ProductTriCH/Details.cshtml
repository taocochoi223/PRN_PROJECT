@model GlassStore.Entities.TriCH.Models.ProductTriCh

@{
    ViewData["Title"] = Model.ProductName;
    var primaryImg = Model.ProductImageTriChes?.FirstOrDefault(x => x.IsPrimary == true)?.ImageUrl
                     ?? Model.ProductImageTriChes?.FirstOrDefault()?.ImageUrl
                     ?? "https://via.placeholder.com/500x500?text=No+Image";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-shop"></i> Tiếp tục mua sắm
            </a>
            <a asp-action="Manage" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại trang quản lý
            </a>
        </div>
    </div>

    <div class="row g-5">
        <!-- Product Images -->
        <div class="col-md-6">
             <div class="card border-0 mb-3">
                 <img id="mainImage" src="@primaryImg" class="img-fluid rounded" alt="@Model.ProductName" style="max-height: 500px; object-fit: contain;">
             </div>
             
             @if (Model.ProductImageTriChes != null && Model.ProductImageTriChes.Count > 1)
             {
                 <div class="d-flex gap-2 ms-1 overflow-auto">
                     @foreach (var img in Model.ProductImageTriChes)
                     {
                         <img src="@img.ImageUrl" 
                              class="img-thumbnail" 
                              style="width: 80px; height: 80px; cursor: pointer; object-fit: cover;" 
                              onclick="changeImage(this.src)"
                              alt="Thumbnail">
                     }
                 </div>
             }
        </div>

        <!-- Product Info -->
        <div class="col-md-6">
            <h6 class="text-primary fw-bold text-uppercase">@Model.CategoryTriCh?.CategoryName</h6>
            <h1 class="display-5 fw-bold mb-3">@Model.ProductName</h1>
            
            <div class="mb-3">
                <h2 class="text-danger fw-bold d-inline-block me-3">@Model.Price.ToString("N0") đ</h2>
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-success">Còn hàng</span>
                }
                else
                {
                    <span class="badge bg-danger">Hết hàng</span>
                }
            </div>

            <p class="lead text-muted">@Model.Description</p>

            <hr class="my-4">

            <!-- Specs -->
             <div class="mb-4">
                 <h5 class="fw-bold">Thông số kỹ thuật</h5>
                 <dl class="row">
                     <dt class="col-sm-3 text-muted">Thương hiệu</dt>
                     <dd class="col-sm-9">@Model.Brand</dd>

                     <dt class="col-sm-3 text-muted">Chất liệu</dt>
                     <dd class="col-sm-9">@Model.Material</dd>

                     <dt class="col-sm-3 text-muted">Loại gọng</dt>
                     <dd class="col-sm-9">@Model.FrameType</dd>
                     
                     <dt class="col-sm-3 text-muted">Kích thước</dt>
                     <dd class="col-sm-9">@Model.Dimensions</dd>
                 </dl>
             </div>
             
             
            
        </div>
    </div>
</div>

