@model GlassStore.Entities.TriCH.Models.ProductTriCh

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "_LayoutAdmin"; // Sử dụng layout Admin cho thống nhất
}

<div class="container my-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary">Thông tin chi tiết sản phẩm</h4>
            <div>
                @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "1")
                {
                    <a asp-action="Edit" asp-route-id="@Model.ProductTriChid" class="btn btn-primary btn-sm">Chỉnh sửa</a>
                }
                <a asp-action="Manage" class="btn btn-secondary btn-sm">Quay lại danh sách</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Cột thông tin chữ -->
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4 text-muted">Mã sản phẩm (ID)</dt>
                        <dd class="col-sm-8 fw-bold">@Model.ProductTriChid</dd>

                        <dt class="col-sm-4 text-muted">Tên sản phẩm</dt>
                        <dd class="col-sm-8">@Model.ProductName</dd>

                        <dt class="col-sm-4 text-muted">Giá bán</dt>
                        <dd class="col-sm-8 text-danger fw-bold">@Model.Price.ToString("N0") đ</dd>

                        <dt class="col-sm-4 text-muted">Số lượng kho</dt>
                        <dd class="col-sm-8">
                            @if (Model.StockQuantity > 0)
                            {
                                <span class="badge bg-success">@Model.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết hàng</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">Danh mục</dt>
                        <dd class="col-sm-8">@Model.CategoryTriCh?.CategoryName</dd>

                        <dt class="col-sm-4 text-muted">Thương hiệu</dt>
                        <dd class="col-sm-8">@Model.Brand</dd>

                        <dt class="col-sm-4 text-muted">Chất liệu</dt>
                        <dd class="col-sm-8">@Model.Material</dd>

                        <dt class="col-sm-4 text-muted">Loại gọng</dt>
                        <dd class="col-sm-8">@Model.FrameType</dd>

                        <dt class="col-sm-4 text-muted">Kích thước</dt>
                        <dd class="col-sm-8">@Model.Dimensions</dd>

                        <dt class="col-sm-4 text-muted">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @(Model.Status == 1 ? "Đang kinh doanh" : "Ngừng kinh doanh")
                        </dd>

                        <dt class="col-sm-4 text-muted">Mô tả</dt>
                        <dd class="col-sm-8 text-muted">@Model.Description</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

