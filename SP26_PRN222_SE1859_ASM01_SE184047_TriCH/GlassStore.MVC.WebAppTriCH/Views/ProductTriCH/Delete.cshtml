@model GlassStore.Entities.TriCH.Models.ProductTriCh

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Xác nhận xóa sản phẩm</h4>
                </div>
                <div class="card-body">
                    <p class="lead text-danger fw-bold">Cảnh báo: Bạn đang thực hiện xóa sản phẩm này. Hành động này không thể hoàn tác!</p>
                    <hr>
                    
                    <div class="row">
                        
                        <div class="col-md-8">
                            <table class="table table-sm">
                                <tr>
                                    <th style="width: 150px;">Tên sản phẩm:</th>
                                    <td>@Model.ProductName</td>
                                </tr>
                                <tr>
                                    <th>Mã sản phẩm (SKU):</th>
                                    <td><code>@Model.Sku</code></td>
                                </tr>
                                <tr>
                                    <th>Danh mục:</th>
                                    <td>@Model.CategoryTriCh?.CategoryName</td>
                                </tr>
                                <tr>
                                    <th>Thương hiệu:</th>
                                    <td>@Model.Brand</td>
                                </tr>
                                <tr>
                                    <th>Giá:</th>
                                    <td class="text-primary fw-bold">@Model.Price.ToString("N0") đ</td>
                                </tr>
                                <tr>
                                    <th>Số lượng tồn kho:</th>
                                    <td>@Model.StockQuantity</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="alert alert-warning mt-4">
                        <i class="bi bi-exclamation-triangle-fill"></i> 
                        <strong>Lưu ý:</strong> Hành động này sẽ xóa sản phẩm khỏi hệ thống.
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ProductTriChid" />
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Manage" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
