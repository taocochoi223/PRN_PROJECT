@page
@model GlassStore.Razor.WebAppTriCH.Pages.CategoryTriCh.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>CategoryTriCh</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CategoryTriCh.CategoryTriChid" />
            <div class="form-group">
                <label asp-for="CategoryTriCh.CategoryName" class="control-label"></label>
                <input asp-for="CategoryTriCh.CategoryName" id="category-name" class="form-control" />
                <span asp-validation-for="CategoryTriCh.CategoryName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryTriCh.Slug" class="control-label"></label>
                <input asp-for="CategoryTriCh.Slug" id="category-slug" class="form-control" />
                <span asp-validation-for="CategoryTriCh.Slug" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryTriCh.ParentId" class="control-label"></label>
                <select asp-for="CategoryTriCh.ParentId" class="form-control" asp-items="ViewBag.ParentId" ></select>
                <span asp-validation-for="CategoryTriCh.ParentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryTriCh.Status" class="control-label"></label>
                <input asp-for="CategoryTriCh.Status" class="form-control" />
                <span asp-validation-for="CategoryTriCh.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="./Manage" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function generateSlug(text) {
            return text.toString().toLowerCase()
                .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ặ|ẵ|â|ấ|ầ|ẩ|ậ|ẫ/g, 'a')
                .replace(/é|è|ẻ|ẹ|ẽ|ê|ế|ề|ể|ệ|ễ/g, 'e')
                .replace(/i|í|ì|ỉ|ị|ĩ/g, 'i')
                .replace(/ó|ò|ỏ|ọ|õ|ô|ố|ồ|ổ|ộ|ỗ|ơ|ớ|ờ|ở|ợ|ỡ/g, 'o')
                .replace(/ú|ù|ủ|ụ|ũ|ư|ứ|ừ|ử|ự|ữ/g, 'u')
                .replace(/ý|ỳ|ỷ|ỵ|ỹ/g, 'y')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, '-')           // Thay khoảng trắng bằng -
                .replace(/[^\w\-]+/g, '')       // Loại bỏ ký tự đặc biệt
                .replace(/\-\-+/g, '-')         // Thay nhiều - bằng một -
                .replace(/^-+/, '')             // Loại bỏ - ở đầu
                .replace(/-+$/, '');            // Loại bỏ - ở cuối
        }

        document.getElementById('category-name').addEventListener('input', function () {
            var name = this.value;
            var slug = generateSlug(name);
            document.getElementById('category-slug').value = slug;
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        var connection = new signalR.HubConnectionBuilder().withUrl("/EyewareHub").build();

        connection.on("HubDelete_categoryTriCh(", function (id) {
            var currentId = parseInt("@Model.CategoryTriCh.CategoryTriChid");
            if (id == currentId) {
                alert("Danh mục này đã bị xoá bởi người khác. Bạn không thể tiếp tục chỉnh sửa!");
                window.location.href = "./Manage";
            }
        });

        connection.start().then(function () {
            console.log("Connected to the SignalR Hub")
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
