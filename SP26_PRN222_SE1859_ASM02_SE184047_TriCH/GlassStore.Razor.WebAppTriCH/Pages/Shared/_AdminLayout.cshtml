<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GlassStore.Razor.WebAppTriCH.styles.css" asp-append-version="true" />
    <style>
        .admin-sidebar {
            min-height: 100vh;
            background-color: #343a40;
        }
        .admin-sidebar .nav-link {
            color: #c2c7d0;
            padding: 10px 20px;
        }
        .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active {
            color: #ffffff;
            background-color: #495057;
            border-radius: 5px;
        }
        .admin-content {
            background-color: #f4f6f9;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block admin-sidebar collapse px-0">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <a href="/" class="text-decoration-none">
                            <h3 class="text-white">Admin Panel</h3>
                        </a>
                        <p class="text-muted small">@User?.FindFirst("FullName")?.Value</p>
                    </div>

                    <ul class="nav flex-column px-2">
                        <li class="nav-item mb-1">
                            <a class="nav-link" asp-page="/Index">
                                <span class="me-2">🏠</span> Desktop/Home
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link" asp-page="/ProductTriCh/Manage">
                                <span class="me-2">📦</span> Quản lý sản phẩm
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link" asp-page="/CategoryTriCh/Manage">
                                <span class="me-2">📦</span> Quản lý danh muc
                            </a>
                        </li>
                    </ul>

                    <hr class="text-white-50 mx-3">
                    <ul class="nav flex-column px-2 mt-auto">
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-page="/Account/Logout">
                                <span class="me-2">🚪</span> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 admin-content pb-5" style="min-height: 100vh;">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">@ViewData["Title"]</h1>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
