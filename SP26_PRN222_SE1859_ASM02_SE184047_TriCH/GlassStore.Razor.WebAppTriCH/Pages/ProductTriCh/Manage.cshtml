@page
@model GlassStore.Razor.WebAppTriCH.Pages.ProductTriCh.ManageModel

@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Manage Products</h1>
        <p>
            <a asp-page="./Create" class="btn btn-success">Create New</a>
        </p>
    </div>
    <form method="get" class="d-flex">
        <input type="text" name="SearchToken" value="@Model.SearchToken" class="form-control me-2" placeholder="Search products..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </form>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.ProductImageTriChes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Sku)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Brand)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.FrameType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Material)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Dimensions)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.StockQuantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.UpdatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductTriCh.FirstOrDefault()!.CategoryTriCh)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody id="table-body">
        @foreach (var item in Model.ProductTriCh)
        {
            <tr id="row-@item.ProductTriChid" data-id="@item.ProductTriChid">
                <td>
                    @if (item.ProductImageTriChes != null && item.ProductImageTriChes.Any())
                    {
                        <img src="@item.ProductImageTriChes.FirstOrDefault()?.ImageUrl" alt="Product Image" style="max-width: 100px; max-height: 100px;" />
                    }
                    else
                    {
                        <span>No Image</span>
                    }
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ProductName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Sku)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Brand)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FrameType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Material)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Dimensions)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.StockQuantity)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CreatedAt)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UpdatedAt)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CategoryTriCh.CategoryName)
                </td>
                <td class="d-flex gap-2">
                    <a asp-page="./Edit" asp-route-id="@item.ProductTriChid" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-page="./Details" asp-route-id="@item.ProductTriChid" class="btn btn-info btn-sm">Details</a>
                    <a asp-page="./Delete" asp-route-id="@item.ProductTriChid" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.PageIndex <= 1 ? "disabled" : "")">
                <a class="page-link" asp-page="./Manage" asp-route-PageIndex="@(Model.PageIndex - 1)" asp-route-SearchToken="@Model.SearchToken">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-page="./Manage" asp-route-PageIndex="@i" asp-route-SearchToken="@Model.SearchToken">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageIndex >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-page="./Manage" asp-route-PageIndex="@(Model.PageIndex + 1)" asp-route-SearchToken="@Model.SearchToken">Next</a>
            </li>
        </ul>
    </nav>
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        var connection = new signalR.HubConnectionBuilder().withUrl("/EyewareHub").build();

        connection.start().then(function () {
            console.log("SignalR connected");
        }).catch(function (err) {
            return console.error(err.toString());
        });

        connection.on("ReceiveHubDelete_productTriCh", function (id) {
            var row = document.getElementById("row-" + id);
            if (row) {
                row.remove();
            }
        });

        connection.on("ReceiveHubCreate_productTriCh", function (item) {
            console.log("New item received:", item);
            var tbody = document.getElementById("table-body");
            if (tbody) {
                var row = document.createElement("tr");
                row.id = "row-" + item.productTriChid;

                // Format dates if they exist
                var createdAt = item.createdAt ? new Date(item.createdAt).toLocaleString() : "";
                var updatedAt = item.updatedAt ? new Date(item.updatedAt).toLocaleString() : "";
                var categoryName = item.categoryName || "";
                var imageHtml = item.imageUrl ? `<img src="${item.imageUrl}" alt="Product Image" style="max-width: 100px; max-height: 100px;" />` : "<span>No Image</span>";

                row.innerHTML = `
                    <td>${imageHtml}</td>
                    <td>${item.productName || ""}</td>
                    <td>${item.sku || ""}</td>
                    <td>${item.brand || ""}</td>
                    <td>${item.price || 0}</td>
                    <td>${item.description || ""}</td>
                    <td>${item.frameType || ""}</td>
                    <td>${item.material || ""}</td>
                    <td>${item.dimensions || ""}</td>
                    <td>${item.stockQuantity || 0}</td>
                    <td>${item.status || 0}</td>
                    <td>${createdAt}</td>
                    <td>${updatedAt}</td>
                    <td>${categoryName}</td>
                    <td>
                        <a href="./Edit?id=${item.productTriChid}">Edit</a> |
                        <a href="./Details?id=${item.productTriChid}">Details</a> |
                        <a href="#" onclick="deleteItem(${item.productTriChid}); return false;">Delete</a>
                    </td>
                `;
                tbody.prepend(row); //chèn hàng mới vào đầu bảng
            }
        });

        connection.on("ReceiveHubUpdate_productTriCh", function(id) {
            console.log("updated row: "+id);
            // optionally reload page or fetch the updated row via AJAX
        });

        function deleteItem(id) {
            if (confirm("Are you sure you want to delete this item?")) {
                connection.invoke("HubDelete_productTriCh", id).catch(function (err) {
                    return console.error(err.toString());
                });
            }
        }
    </script>
}
