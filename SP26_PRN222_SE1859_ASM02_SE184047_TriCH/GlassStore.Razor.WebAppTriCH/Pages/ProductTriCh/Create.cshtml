@page
@model GlassStore.Razor.WebAppTriCH.Pages.ProductTriCh.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>ProductTriCh</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProductTriCh.ProductName" class="control-label"></label>
                <input asp-for="ProductTriCh.ProductName" class="form-control" />
                <span asp-validation-for="ProductTriCh.ProductName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Sku" class="control-label"></label>
                <input asp-for="ProductTriCh.Sku" class="form-control" />
                <span asp-validation-for="ProductTriCh.Sku" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.CategoryTriChid" class="control-label"></label>
                <select asp-for="ProductTriCh.CategoryTriChid" class ="form-control" asp-items="ViewBag.CategoryTriChid" ></select>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Brand" class="control-label"></label>
                <input asp-for="ProductTriCh.Brand" class="form-control" />
                <span asp-validation-for="ProductTriCh.Brand" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Price" class="control-label"></label>
                <input asp-for="ProductTriCh.Price" class="form-control" />
                <span asp-validation-for="ProductTriCh.Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Description" class="control-label"></label>
                <input asp-for="ProductTriCh.Description" class="form-control" />
                <span asp-validation-for="ProductTriCh.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.FrameType" class="control-label"></label>
                <select asp-for="ProductTriCh.FrameType" class="form-control">
                    <option value="">-- Select Frame Type --</option>
                    <option value="Full Rim">Full Rim (Nguyên khung)</option>
                    <option value="Half Rim">Half Rim (Nửa khung)</option>
                    <option value="Rimless">Rimless (Không khung)</option>
                    <option value="Browline">Browline</option>
                    <option value="Aviator">Aviator</option>
                    <option value="Wayfarer">Wayfarer</option>
                    <option value="Round">Round (Tròn)</option>
                    <option value="Square">Square (Vuông)</option>
                </select>
                <span asp-validation-for="ProductTriCh.FrameType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Material" class="control-label"></label>
                <input asp-for="ProductTriCh.Material" class="form-control" />
                <span asp-validation-for="ProductTriCh.Material" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.Dimensions" class="control-label"></label>
                <input asp-for="ProductTriCh.Dimensions" class="form-control" />
                <span asp-validation-for="ProductTriCh.Dimensions" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductTriCh.StockQuantity" class="control-label"></label>
                <input asp-for="ProductTriCh.StockQuantity" class="form-control" />
                <span asp-validation-for="ProductTriCh.StockQuantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="./Manage" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        var connection = new signalR.HubConnectionBuilder().withUrl("/EyewareHub").build();
        connection.start().then(function () {
            console.log("Connected to the SignalR Hub");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
