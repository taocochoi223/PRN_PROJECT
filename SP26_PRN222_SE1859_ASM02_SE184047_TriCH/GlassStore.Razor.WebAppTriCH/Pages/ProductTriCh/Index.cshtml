@page
@model GlassStore.Razor.WebAppTriCH.Pages.ProductTriCh.IndexModel

@{
    ViewData["Title"] = "Products";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Products</h1>

    <div class="row row-cols-1 row-cols-md-3 g-4" id="product-list">
        @foreach (var item in Model.ProductTriCh)
        {
            <div class="col" id="col-@item.ProductTriChid" data-id="@item.ProductTriChid">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@item.ProductName</h5>
                        <p class="card-text text-muted mb-1">Brand: @item.Brand</p>
                        <p class="card-text text-muted mb-2">Category: @item.CategoryTriCh?.CategoryName</p>
                        <h6 class="card-subtitle mb-3 text-primary">@item.Price.ToString("C")</h6>
                        <p class="card-text" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        var connection = new signalR.HubConnectionBuilder().withUrl("/EyewareHub").build();

        connection.start().then(function () {
            console.log("SignalR connected");
        }).catch(function (err) {
            return console.error(err.toString());
        });

        // If product is deleted, remove it from the view
        connection.on("ReceiveHubDelete_productTriCh", function (id) {
            var col = document.getElementById("col-" + id);
            if (col) {
                col.remove();
            }
        });

        // If a new product is added, create a new card component
        connection.on("ReceiveHubCreate_productTriCh", function (item) {
            var productList = document.getElementById("product-list");
            if (productList) {
                var newCol = document.createElement("div");
                newCol.className = "col";
                newCol.id = "col-" + item.productTriChid;

                var categoryName = item.categoryName || "Uncategorized";
                var priceString = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(item.price || 0);

                newCol.innerHTML = `
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">${item.productName || ""}</h5>
                            <p class="card-text text-muted mb-1">Brand: ${item.brand || ""}</p>
                            <p class="card-text text-muted mb-2">Category: ${categoryName}</p>
                            <h6 class="card-subtitle mb-3 text-primary">${priceString}</h6>
                            <p class="card-text" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                ${item.description || ""}
                            </p>
                        </div>
                    </div>
                `;
                productList.prepend(newCol); // Insert at the top
            }
        });
    </script>
}
