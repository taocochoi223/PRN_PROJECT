@page "/producttriches"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using GlassStore.Entities.TriCH.Models
@using GlassStore.Repositories.TriCH.DBContext
@inject GlassStore.Services.TriCH.IProductTriCHService _productService;

<PageTitle>Product Management</PageTitle>

<h1>Product Management</h1>

<p>
    <a href="producttriches/create" class="btn btn-primary">Create New</a>
</p>

@* Chỉ hiện thông báo Loading nhỏ phía trên nếu đang load lại, không chặn render Grid *@
@if (isLoading)
{
    <div class="alert alert-info py-1">Updating data...</div>
}

<QuickGrid Class="table table-striped" ItemsProvider="productProvider" Pagination="pagination">
    <TemplateColumn Context="producttrich" Title="Images">
        @if (producttrich.ProductImageTriChes != null && producttrich.ProductImageTriChes.Any())
        {
            var primaryImage = producttrich.ProductImageTriChes.FirstOrDefault(i => i.IsPrimary == true) ?? producttrich.ProductImageTriChes.First();
            <img src="@primaryImage.ImageUrl" alt="Product Image" style="width: 50px; height: 50px; object-fit: cover;" />
        }
        else
        {
            <span class="text-muted">No Image</span>
        }
    </TemplateColumn>
    <PropertyColumn Property="producttrich => producttrich.ProductName" Title="Name" Sortable="true" />
    <PropertyColumn Property="producttrich => producttrich.Sku" Title="SKU" Sortable="true" />
    <PropertyColumn Property="producttrich => producttrich.Brand" Sortable="true" />
    <PropertyColumn Property="producttrich => producttrich.Price" Format="C0" Sortable="true" />
    <PropertyColumn Property="producttrich => producttrich.StockQuantity" Title="Stock" Sortable="true" />
    
    <TemplateColumn Context="producttrich" Title="Actions">
        <div class="btn-group">
            <a class="btn btn-sm btn-info text-white" href="@($"productcolortriches?productid={producttrich.ProductTriChid}")">
                <i class="bi bi-palette"></i> Màu
            </a>
            <a class="btn btn-sm btn-secondary" href="@($"productimagetriches?productid={producttrich.ProductTriChid}")">
                <i class="bi bi-image"></i> Ảnh
            </a>
            <a class="btn btn-sm btn-outline-info" href="@($"producttriches/details?producttrichid={producttrich.ProductTriChid}")">
                <i class="bi bi-eye"></i>
            </a>
            <a class="btn btn-sm btn-outline-primary" href="@($"producttriches/edit?producttrichid={producttrich.ProductTriChid}")">
                <i class="bi bi-pencil"></i>
            </a>
            <a class="btn btn-sm btn-outline-danger" href="@($"producttriches/delete?producttrichid={producttrich.ProductTriChid}")">
                <i class="bi bi-trash"></i>
            </a>
        </div>
    </TemplateColumn>
</QuickGrid>

<Paginator State="@pagination" />

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    GridItemsProvider<ProductTriCh> productProvider = default!;
    bool isLoading = false; // Mặc định là false để QuickGrid được render ngay

    protected override void OnInitialized()
    {
        productProvider = async request =>
        {
            isLoading = true;
            StateHasChanged();

            int pageSize = request.Count ?? pagination.ItemsPerPage;
            int pageIndex = request.StartIndex / pageSize; 

            var (items, totalCount) = await _productService.GetAllProductPagedAsync(pageIndex + 1, pageSize);

            isLoading = false;
            StateHasChanged();

            return GridItemsProviderResult.From(
                items: items,
                totalItemCount: totalCount);
        };
    }
}


