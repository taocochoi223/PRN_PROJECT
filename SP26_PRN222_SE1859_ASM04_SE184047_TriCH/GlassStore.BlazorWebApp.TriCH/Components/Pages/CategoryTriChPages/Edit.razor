@page "/categorytriches/edit"
@using Microsoft.EntityFrameworkCore
@using GlassStore.Entities.TriCH.Models
@inject GlassStore.Services.TriCH.ICategoryTriCHService _service;
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>CategoryTriCh</h2>
<hr />
@if (CategoryTriCh is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="CategoryTriCh" OnValidSubmit="UpdateCategoryTriCh" FormName="edit" Enhance>
                <AntiforgeryToken />
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="CategoryTriCh.CategoryTriChid" value="@CategoryTriCh.CategoryTriChid" />
                <div class="mb-3">
                    <label for="categoryname" class="form-label">CategoryName:</label>
                    <InputText id="categoryname" @bind-Value="CategoryTriCh.CategoryName" class="form-control" />
                    <ValidationMessage For="() => CategoryTriCh.CategoryName" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="slug" class="form-label">Slug:</label>
                    <InputText id="slug" @bind-Value="CategoryTriCh.Slug" class="form-control" />
                    <ValidationMessage For="() => CategoryTriCh.Slug" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="parentid" class="form-label">ParentId:</label>
                    <InputNumber id="parentid" @bind-Value="CategoryTriCh.ParentId" class="form-control" />
                    <ValidationMessage For="() => CategoryTriCh.ParentId" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="status" class="form-label">Status:</label>
                    <InputSelect id="status" @bind-Value="CategoryTriCh.Status" class="form-select">
                        <option value="1">Active (True)</option>
                        <option value="0">Inactive (False)</option>
                    </InputSelect>
                    <ValidationMessage For="() => CategoryTriCh.Status" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/categorytriches">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int CategoryTriChid { get; set; }

    [SupplyParameterFromForm]
    private CategoryTriCh? CategoryTriCh { get; set; }

    [SupplyParameterFromForm]
    private string StatusString { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        CategoryTriCh ??= await _service.GetCategoryByIdAsync(CategoryTriChid);
        if(CategoryTriCh is null)
        {
            NavigationManager.NavigateTo("/categorytriches");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateCategoryTriCh()
    {
        try
        {
            await _service.UpdateCategoryAsync(CategoryTriCh);
        }
        catch (Exception ex)
        {
            throw new Exception($"Error updating category: {ex.Message}", ex);
        }

        NavigationManager.NavigateTo("/categorytriches");
    }


   
}
