@page "/categorytriches"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using GlassStore.Entities.TriCH.Models
@using GlassStore.Repositories.TriCH.DBContext
@inject GlassStore.Services.TriCH.ICategoryTriCHService _service;

<PageTitle>Category Management</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Category Management</h1>
    <a href="categorytriches/create" class="btn btn-success">Create New</a>
</div>

<div class="mb-3 d-flex gap-2">
    <input type="text" class="form-control w-25" placeholder="Search category name..."
           value="@searchTerm" @oninput="HandleSearch" />
</div>

@if (isLoading)
{
    <div class="alert alert-info py-1">Updating data...</div>
}

<QuickGrid @ref="myGrid" Class="table table-striped table-hover" ItemsProvider="categoryProvider" Pagination="pagination">
    <PropertyColumn Property="c => c.CategoryName" Title="Category Name" Sortable="true" />
    <PropertyColumn Property="c => c.Slug" Title="Slug" Sortable="true" />

    <TemplateColumn Title="Status" Context="c">
        @if (c.Status == 1)
        {
            <span class="badge bg-success">Active</span>
        }
        else
        {
            <span class="badge bg-secondary">Inactive</span>
        }
    </TemplateColumn>

    <TemplateColumn Title="Actions" Context="c">
        <div class="d-flex gap-1">
            <a class="btn btn-sm btn-primary" href="@($"categorytriches/edit?categorytrichid={c.CategoryTriChid}")">
                Edit
            </a>
            <a class="btn btn-sm btn-info text-white" href="@($"categorytriches/details?categorytrichid={c.CategoryTriChid}")">
                Details
            </a>
            <a class="btn btn-sm btn-danger" href="@($"categorytriches/delete?categorytrichid={c.CategoryTriChid}")">
                Delete
            </a>
        </div>
    </TemplateColumn>
</QuickGrid>

<div class="mt-3">
    <Paginator State="@pagination" />
</div>
@code {
    QuickGrid<CategoryTriCh> myGrid = default!;
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private GridItemsProvider<CategoryTriCh> categoryProvider = default!;
    private bool isLoading;
    private string searchTerm = "";

    private System.Timers.Timer? _debounceTimer;

    protected override void OnInitialized()
    {
        categoryProvider = LoadCategories;
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();

        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (s, ev) =>
        {
            await InvokeAsync(async () =>
            {
                if (myGrid != null)
                {
                    await myGrid.RefreshDataAsync();
                }
            });
            _debounceTimer.Stop();
        };
        _debounceTimer.Start();
    }

    private async ValueTask<GridItemsProviderResult<CategoryTriCh>> LoadCategories(GridItemsProviderRequest<CategoryTriCh> request)
    {
        isLoading = true;

        try
        {
            int pageSize = request.Count ?? pagination.ItemsPerPage;
            int pageIndex = request.StartIndex / pageSize;

            var (items, totalCount) = await _service.GetAllCategoriesPagedAsync(pageIndex, pageSize, searchTerm);

            return GridItemsProviderResult.From(items, totalCount);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
