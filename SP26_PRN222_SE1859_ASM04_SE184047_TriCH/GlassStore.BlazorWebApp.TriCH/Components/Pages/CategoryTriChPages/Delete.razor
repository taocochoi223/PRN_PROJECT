@page "/categorytriches/delete"
@attribute [Authorize(Roles = "1")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using GlassStore.Entities.TriCH.Models
@inject GlassStore.Services.TriCH.ICategoryTriCHService _service;
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>CategoryTriCh</h2>
    <hr />
    @if (categorytrich is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">CategoryName</dt>
            <dd class="col-sm-10">@categorytrich.CategoryName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Slug</dt>
            <dd class="col-sm-10">@categorytrich.Slug</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ParentId</dt>
            <dd class="col-sm-10">@categorytrich.ParentId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@categorytrich.Status</dd>
        </dl>
        <EditForm method="post" Model="categorytrich" OnValidSubmit="DeleteCategoryTriCh" FormName="delete" Enhance>
            <input type="hidden" name="categorytrich.CategoryTriChid" value="@categorytrich.CategoryTriChid" />
            <div class="mt-4 d-flex gap-1">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a href="/categorytriches" class="btn btn-secondary">Back to List</a>
            </div>
        </EditForm>
    }
</div>

@code {
    private CategoryTriCh? categorytrich;

    [SupplyParameterFromQuery]
    private int CategoryTriChid { get; set; }


    protected override async Task OnInitializedAsync()
    {
        categorytrich ??= await _service.GetCategoryByIdAsync(CategoryTriChid);
        if(categorytrich is null)
        {
            NavigationManager.NavigateTo("/categorytriches");
        }
    }

    private async Task DeleteCategoryTriCh()
    {
        try
        {
            await _service.DeleteCategoryAsync(CategoryTriChid);
        }
        catch (Exception ex)
        {
            throw new Exception($"Error deleting category: {ex.Message}", ex);
        }
        NavigationManager.NavigateTo("/categorytriches", forceLoad: true);
    }

}
